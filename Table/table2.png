e,\"can_see_analytics_viewer_role\":true,\"show_ui_polish\":true,\"show_conversation_topic\":true,\"show_classification_tab\":true,\"show_project_tab\":true,\"show_impact_tab\":true,\"show_connector_project_cols\":true,\"custom-time-range-selector\":true,\"show_benchmark\":true,\"temp-sidebar-chat\":true,\"show_ai_champions_button\":true},\"is_device_based\":false,\"passed\":false},\"1126845738\":{\"name\":\"1126845738\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"offices\":{\"nyc\":{\"office_label\":\"New York City\",\"developer_instructions\":\"The user clicked a ChatGPT homepage doodle. Do not ask them to upload or show the doodle. Concisely explain the event behind the doodle with concrete details: what date \u0026 time the event is in bold, who it centers on or brings together, what the event is, where it happens, why it matters, and how the doodle's visual details connect to that story. Keep the event explanation to at most 1-2 short paragraphs. Make sure you use the right tense for when the event is happening. Use the map widget to ground your answer in the doodle's New York City context. If you can identify the most relevant venue, neighborhood, or event location, include it on the map while you explain the doodle. Answer the user's visible prompt using this doodle context:\",\"light_image_url\":\"https://persistent.oaistatic.com/chatgpt/doodles/2026-05-21-to-2026-05-24-manual-dark-oled-review/may-21/nyc/may-21_NYC_light-mode.png\",\"starter_question\":\"Can you explain the context behind this ChatGPT homepage doodle? It was created for Grand Central Food Fair 2026 in New York City, using food stalls, vendor awnings, market energy, Midtown street fair. What event is it referencing, and how do those details tell the story?\",\"dark_image_url\":\"https://persistent.oaistatic.com/chatgpt/doodles/2026-05-21-to-2026-05-24-manual-dark-oled-review/may-21/nyc/may-21_NYC_dark-mode.png\",\"event_title\":\"Grand Central Food Fair 2026\",\"starter_prompt\":\"What is Grand Central Food Fair 2026, and what happens at the Midtown East street fair?\",\"oled_image_url\":\"https://persistent.oaistatic.com/chatgpt/doodles/2026-05-21-to-2026-05-24-manual-dark-oled-review/may-21/nyc/may-21_NYC_oled-mode.png\"},\"sf\":{\"developer_instructions\":\"The user clicked a ChatGPT homepage doodle. Do not ask them to upload or show the doodle. Concisely explain the event behind the doodle with concrete details: what date \u0026 time the event is in bold, who it centers on or brings together, what the event is, where it happens, why it matters, and how the doodle's visual details connect to that story. Keep the event explanation to at most 1-2 short paragraphs. Make sure you use the right tense for when the event is happening. Use the map widget to ground your answer in the doodle's San Francisco context. If you can identify the most relevant venue, neighborhood, or event location, include it on the map while you explain the doodle. Answer the user's visible prompt using this doodle context:\",\"event_title\":\"AAPI Heritage Month SF Downtown Block Party ft. Jai Wolf \u0026 Friends\",\"oled_image_url\":\"https://persistent.oaistatic.com/chatgpt/doodles/2026-05-21-to-2026-05-24-manual-dark-oled-review/may-21/sf/may-21_SF_oled-mode.png\",\"starter_prompt\":\"What is AAPI Heritage Month SF Downtown Block Party ft. Jai Wolf \u0026 Friends, and what happens at the downtown block party?\",\"office_label\":\"San Francisco\",\"light_image_url\":\"https://persistent.oaistatic.com/chatgpt/doodles/2026-05-21-to-2026-05-24-manual-dark-oled-review/may-21/sf/may-21_SF_light-mode.png\",\"dark_image_url\":\"https://persistent.oaistatic.com/chatgpt/doodles/2026-05-21-to-2026-05-24-manual-dark-oled-review/may-21/sf/may-21_SF_dark-mode.png\",\"starter_question\":\"Can you explain the context behind this ChatGPT homepage doodle? It was created for AAPI Heritage Month SF Downtown Block Party ft. Jai Wolf \u0026 Friends in San Francisco, using downtown block-party energy, AAPI celebration, music/DJ set, street-festival atmosphere. What event is it referencing, and how do those details tell the story?\"}}},\"is_device_based\":false,\"passed\":false},\"1104813507\":{\"name\":\"1104813507\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"options\":[{\"key\":\"image_card_v1\",\"label\":\"ImageCardV1\"},{\"key\":\"image_card_v2_single\",\"label\":\"ImageCardV2: Single\"},{\"label\":\"ImageCardV2: Two\",\"key\":\"image_card_v2_two\"},{\"label\":\"ImageCardV2: Five\",\"key\":\"image_card_v2_five\"},{\"key\":\"image_card_v2_cta\",\"label\":\"ImageCardV2: CTA\"},{\"label\":\"ProductCardV2: Single\",\"key\":\"product_card_v2_single\"},{\"key\":\"product_card_v2_two_horizontal\",\"label\":\"ProductCardV2: Two Horizontal\"},{\"key\":\"product_card_v2_two_vertical\",\"label\":\"ProductCardV2: Two Vertical\"},{\"key\":\"product_card_v2_four\",\"label\":\"ProductCardV2: Four\"},{\"key\":\"product_card_v2_five\",\"label\":\"ProductCardV2: Five\"},{\"key\":\"product_card_v2_temu_1\",\"label\":\"Temu 1\"},{\"key\":\"product_card_v2_temu_2\",\"label\":\"Temu 2\"},{\"label\":\"Temu 3\",\"key\":\"product_card_v2_temu_3\"},{\"label\":\"Personalized Ads MVP 1\",\"key\":\"image_card_v2_personalized_ads_mvp_1\"},{\"key\":\"image_card_v2_personalized_ads_mvp_2\",\"label\":\"Personalized Ads MVP 2\"}]},\"is_device_based\":false,\"passed\":false},\"1598825633\":{\"name\":\"1598825633\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":true,\"denominator\":0},\"is_device_based\":false,\"passed\":false},\"371023604\":{\"name\":\"371023604\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"controls\":{\"connector_2128aebfecb84f64a069897515042a44\":{\"gmail_recipient_domains\":{\"display_in_ui\":true,\"enforce\":true},\"email_recipient_domains\":{\"enforce\":true,\"display_in_ui\":true}},\"connector_69c53ce437208190a51498354624deaf\":{\"email_recipient_domains\":{\"display_in_ui\":false,\"enforce\":false}},\"connector_69c68b8f7afc8190af51010f6bfe8fae\":{\"email_recipient_domains\":{\"display_in_ui\":false,\"enforce\":false}},\"connector_4aaab2856305417b993eca9a216aaf6e\":{\"email_recipient_domains\":{\"enforce\":false,\"display_in_ui\":false}}}},\"is_device_based\":false,\"passed\":false},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enable_web_search\":false,\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\",\"user_prompt_key\":\"good_option\"},\"is_device_based\":false,\"passed\":false},\"3774971069\":{\"name\":\"3774971069\",\"rule_id\":\"3wuW1nDxShKMpRhW6RD9w6-3wuW1lYvpZBi6rK0vJHwd4\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"tooltip\":\"Only includes tokens tracked after token-based pricing was enabled\"},\"is_device_based\":false,\"passed\":false},\"3230069703\":{\"name\":\"3230069703\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"expirySeconds\":15},\"is_device_based\":false,\"passed\":false},\"1638994742\":{\"name\":\"1638994742\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"web_disabled_file_previewer_types\":[]},\"is_device_based\":false,\"passed\":false},\"2801269291\":{\"name\":\"2801269291\",\"rule_id\":\"3GogUOjtjNxIDzmIRRwIBt-3GogUMEqRvoek9ONgJB5ir\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"apps\":[\"asdk_app_693ca6ce2db08191bb52d66743c65184\",\"connector_76869538009648d5b282a4bb21c3d157\",\"asdk_app_69377d07cd9c8191a988f06f15b8c674\",\"connector_5f3c8c41a1e54ad7a76272c89e2554fa\",\"connector_68df33b1a2d081918778431a9cfca8ba\",\"connector_69312da8e4dc81919370cb86fd172b6c\"]},\"is_device_based\":false,\"passed\":true},\"2712016364\":{\"name\":\"2712016364\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"staleTimeMs\":300001,\"gcTimeMs\":1800001},\"is_device_based\":false,\"passed\":false},\"2699916856\":{\"name\":\"2699916856\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"custom_headers\":{}},\"is_device_based\":false,\"passed\":false},\"3406517345\":{\"name\":\"3406517345\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"passed\":false},\"2888003541\":{\"name\":\"2888003541\",\"rule_id\":\"default\",\"secondary_exposu