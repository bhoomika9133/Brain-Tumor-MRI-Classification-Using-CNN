g#ce3544" fill="currentColor"></use></svg></button><span class="" data-state="closed"><button class="text-token-text-primary hover:bg-token-bg-tertiary flex size-9 items-center justify-center rounded-full p-1.5 transition-colors select-none disabled:opacity-40 disabled:hover:bg-transparent" type="button" id="radix-_r_ls_" aria-haspopup="menu" aria-expanded="false" data-state="closed"><div class="flex items-center gap-1 text-sm font-medium font-normal"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="block"><use href="/cdn/assets/sprites-core-eb6cc3cb.svg#1a3695" fill="currentColor"></use></svg></div></button></span><span class="" data-state="closed"><button aria-label="Open editor" class="flex items-center transition-colors select-none hover:[&amp;_.icon]:text-token-text-primary hover:bg-token-bg-tertiary rounded-full size-9 justify-center p-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon text-token-text-primary"><use href="/cdn/assets/sprites-core-eb6cc3cb.svg#19c64a" fill="currentColor"></use></svg></button></span></div></div></div></div></div><div class="writing-block-editor markdown-new-styling relative flow-root pt-(--writing-block-editor-pt) pe-(--writing-block-editor-pr) pb-(--writing-block-editor-pb) ps-(--writing-block-editor-pl)" style="--writing-block-editor-pt: calc(8 * var(--spacing)); --writing-block-editor-pr: calc(20 * var(--spacing)); --writing-block-editor-pb: calc(16 * var(--spacing)); --writing-block-editor-pl: calc(20 * var(--spacing));"><div class="ProseMirror markdown prose dark:prose-invert w-full min-h-6 break-words focus:outline-none" data-writing-block-fullscreen-editor-region="true" data-writing-block-fullscreen-editor-layout="inline" contenteditable="true" aria-disabled="false" dir="auto" translate="no"><h1><span>Tables Folder</span></h1><p><span>This folder contains the experimental result tables used in the Brain Tumor MRI Classification project.</span></p><h2><span>Included Tables</span></h2><h3><span>Table I: Comparison of CNN Models with and without Data Augmentation</span></h3><table><tbody><tr><th><span>Model</span></th><th><span>Accuracy (%)</span></th></tr><tr><td><span>CNN Without Augmentation</span></td><td><span>78.38</span></td></tr><tr><td><span>CNN With Augmentation</span></td><td><span>65.25</span></td></tr></tbody></table><h3><span>Table II: Performance Comparison of CNN Architectures</span></h3><table><tbody><tr><td><span>CNN Architecture</span></td><td><span>Accuracy (%)</span></td></tr><tr><td><span>Simple CNN</span></td><td><span>80.69</span></td></tr><tr><td><span>Medium CNN</span></td><td><span>80.50</span></td></tr><tr><td><span>Deep CNN</span></td><td><span>77.94</span></td></tr></tbody></table><h2><span>Table Description</span></h2><p><span>These tables present the experimental results obtained from different CNN configurations and evaluate the impact of data augmentation and model complexity on brain tumor classification performance.</span></p></div></div></div><div aria-hidden="true" class="pointer-events-none absolute inset-0 z-2 rounded-[24px] shadow-[inset_0px_0px_0px_1px_rgba(0,0,0,0.07)]" data-writing-block-fullscreen-shell-border="true"></div></div></div>
