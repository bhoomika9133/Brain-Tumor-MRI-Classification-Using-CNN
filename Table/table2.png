g#ce3544" fill="currentColor"></use></svg></button><span class="" data-state="closed"><button class="text-token-text-primary hover:bg-token-bg-tertiary flex size-9 items-center justify-center rounded-full p-1.5 transition-colors select-none disabled:opacity-40 disabled:hover:bg-transparent" type="button" id="radix-_r_ht_" aria-haspopup="menu" aria-expanded="false" data-state="closed"><div class="flex items-center gap-1 text-sm font-medium font-normal"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="block"><use href="/cdn/assets/sprites-core-eb6cc3cb.svg#1a3695" fill="currentColor"></use></svg></div></button></span><span class="" data-state="closed"><button aria-label="Open editor" class="flex items-center transition-colors select-none hover:[&amp;_.icon]:text-token-text-primary hover:bg-token-bg-tertiary rounded-full size-9 justify-center p-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon text-token-text-primary"><use href="/cdn/assets/sprites-core-eb6cc3cb.svg#19c64a" fill="currentColor"></use></svg></button></span></div></div></div></div></div><div class="writing-block-editor markdown-new-styling relative flow-root pt-(--writing-block-editor-pt) pe-(--writing-block-editor-pr) pb-(--writing-block-editor-pb) ps-(--writing-block-editor-pl)" style="--writing-block-editor-pt: calc(8 * var(--spacing)); --writing-block-editor-pr: calc(20 * var(--spacing)); --writing-block-editor-pb: calc(16 * var(--spacing)); --writing-block-editor-pl: calc(20 * var(--spacing));"><div class="ProseMirror markdown prose dark:prose-invert w-full min-h-6 break-words focus:outline-none" data-writing-block-fullscreen-editor-region="true" data-writing-block-fullscreen-editor-layout="inline" contenteditable="true" aria-disabled="false" dir="auto" translate="no"><h1><span>Brain Tumor MRI Classification Using CNN</span></h1><p><span>This repository presents a Convolutional Neural Network (CNN) based framework for Brain Tumor MRI classification.</span></p><p><span>The proposed model classifies MRI images into four categories:</span></p><ul data-spread="false"><li><p><span>Glioma Tumor</span></p></li><li><p><span>Meningioma Tumor</span></p></li><li><p><span>Pituitary Tumor</span></p></li><li><p><span>No Tumor</span></p></li></ul><h2><span>Repository Structure</span></h2><ul data-spread="false"><li><p><span>code/</span></p></li><li><p><span>figures/</span></p></li><li><p><span>report/</span></p></li></ul><h2><span>Research Questions</span></h2><ul data-spread="false"><li><p><span>RQ1: Can CNN models accurately classify brain tumor MRI images?</span></p></li><li><p><span>RQ2: Does data augmentation improve CNN performance?</span></p></li><li><p><span>RQ3: How does model complexity affect accuracy?</span></p></li><li><p><span>RQ4: What causes misclassification?</span></p></li><li><p><span>RQ5: How does dropout regularization affect performance?</span></p></li></ul><h2><span>Methodology</span></h2><p><span>MRI Dataset → Preprocessing → CNN Model → Training → Evaluation → Prediction</span></p><h2><span>Results</span></h2><p><span>The CNN model achieved satisfactory classification performance for brain tumor MRI images.</span></p><h2><span>Author</span></h2><p><span>Bhoomika Basavaraju</span></p><h2><span>References</span></h2><ul data-spread="false"><li><p><span>Kaggle Brain Tumor MRI Dataset</span></p></li><li><p><span>TensorFlow and Keras documentation</span></p></li></ul></div></div></div><div aria-hidden="true" class="pointer-events-none absolute inset-0 z-2 rounded-[24px] shadow-[inset_0px_0px_0px_1px_rgba(0,0,0,0.07)]" data-writing-block-fullscreen-shell-border="true"></div></div></div>
<hr data-start="1135" data-end="1138">
